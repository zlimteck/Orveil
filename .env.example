# MongoDB
MONGO_USER=orveil
MONGO_PASS=orveil_pass

# Security — required, generate before deploying
# JWT_SECRET: openssl rand -hex 32
# ADMIN_PASSWORD: choose a strong password
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Set to true only if serving over HTTPS (reverse proxy with TLS)
COOKIE_SECURE=false

# Only needed if frontend and backend are on different origins (split deployment)
# Leave empty for the standard single-container setup
FRONTEND_URL=

# Encryption at rest (optional but recommended)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Prometheus metrics endpoint (optional)
# Generate with: openssl rand -hex 32
# Must match bearer_token in prometheus.yml
METRICS_TOKEN=
