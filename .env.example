# MongoDB
MONGO_USER=orveil
MONGO_PASS=orveil_pass

# Security — change these before exposing publicly
JWT_SECRET=orveil-change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=orveil

# Encryption at rest (optional but recommended)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Prometheus metrics endpoint (optional)
# Generate with: openssl rand -hex 32
# Must match bearer_token in prometheus.yml
METRICS_TOKEN=
