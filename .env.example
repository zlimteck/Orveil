# MongoDB
MONGO_USER=orveil
MONGO_PASS=orveil_pass

# Security — required, generate before deploying
# JWT_SECRET: openssl rand -hex 32
# ADMIN_PASSWORD: if left empty, a random password is generated and printed in container logs on first start
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Public URL of the app — controls session cookie security automatically
# http://... → Secure flag off (works over HTTP)
# https://... → Secure flag on (requires HTTPS, e.g. behind Cloudflare/Nginx)
FRONTEND_URL=http://localhost:3050

# Docker socket proxy URL (set when using docker-socket-proxy in compose)
DOCKER_PROXY_URL=http://docker-proxy:2375

# Encryption at rest (optional but recommended)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Prometheus metrics endpoint (optional)
# Generate with: openssl rand -hex 32
# Must match bearer_token in prometheus.yml
METRICS_TOKEN=
