# MongoDB
MONGO_USER=notifhub
MONGO_PASS=notifhub_pass

# JWT — change this in production
JWT_SECRET=notifhub-change-me-in-production

# Encryption key for sensitive monitor credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Default admin account (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=notifhub

# Backend API URL used at frontend build time
VITE_API_URL=http://localhost:5050
